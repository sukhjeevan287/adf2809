{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "mydatafactoryfebmor"
		},
		"AzureSqlDatabaseLS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabaseLS'"
		},
		"AzureSqlDatabaseNewLS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabaseNewLS'"
		},
		"AzureDataLakeStorageLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://blobstorageforademorning.dfs.core.windows.net/"
		},
		"AzureKeyVaultLS_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultdevmorning.vault.azure.net/"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "devmorningbatch.database.windows.net"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AdventureWorks"
		},
		"AzureSqlDatabaseLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dbadmin"
		},
		"AzureSqlDatabaseNewLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "trainingdbdev.database.windows.net"
		},
		"AzureSqlDatabaseNewLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "adventureworks"
		},
		"AzureSqlDatabaseNewLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dbadmin"
		},
		"RestServiceDS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://jsonplaceholder.typicode.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "mydatafactoryfebmor_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlDatabaseLS_password": {
						"value": "[parameters('AzureSqlDatabaseLS_password')]"
					},
					"AzureSqlDatabaseNewLS_password": {
						"value": "[parameters('AzureSqlDatabaseNewLS_password')]"
					},
					"AzureDataLakeStorageLS_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorageLS_properties_typeProperties_url')]"
					},
					"AzureKeyVaultLS_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVaultLS_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_server')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_database')]"
					},
					"AzureSqlDatabaseLS_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabaseLS_properties_typeProperties_userName')]"
					},
					"AzureSqlDatabaseNewLS_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabaseNewLS_properties_typeProperties_server')]"
					},
					"AzureSqlDatabaseNewLS_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabaseNewLS_properties_typeProperties_database')]"
					},
					"AzureSqlDatabaseNewLS_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabaseNewLS_properties_typeProperties_userName')]"
					},
					"RestServiceDS_properties_typeProperties_url": {
						"value": "[parameters('RestServiceDS_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "mydatafactoryfebmor_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mydatafactoryfebmor_ArmTemplate_0')]"
			]
		},
		{
			"name": "mydatafactoryfebmor_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mydatafactoryfebmor_ArmTemplate_1')]"
			]
		}
	]
}